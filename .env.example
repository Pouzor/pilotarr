# ── Quick Install (pre-built images, no git clone needed) ──────────────────
# curl -O https://raw.githubusercontent.com/Pouzor/pilotarr/main/docker-compose.release.yml
# curl -O https://raw.githubusercontent.com/Pouzor/pilotarr/main/.env.example
# cp .env.example .env   # then edit the secrets below
# docker compose -f docker-compose.release.yml up -d
# ───────────────────────────────────────────────────────────────────────────

# ── Database ──────────────────────────────────────────
DB_HOST=mysql          # keep as "mysql" when using docker-compose
DB_PORT=3306
DB_NAME=pilotarr_db
DB_USER=pilotarr_user
DB_PASSWORD=change_me
MYSQL_ROOT_PASSWORD=change_me_root

# ── Backend API ────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_KEY=change_me_api_key
WEBHOOK_SECRET=change_me_webhook_secret   # required — generate with: openssl rand -hex 32
DEBUG=false

# ── Security ───────────────────────────────────────────
SECRET_KEY=change_me_secret_key   # generate with: openssl rand -hex 32

# ── Default admin account (only used at first startup) ─────────────────────
DEFAULT_ADMIN_PASSWORD=change_me_admin   # change this before first run

# ── CORS — covers local dev (Vite :5173); restrict to your domain in prod ───
CORS_ORIGINS=["http://localhost","http://localhost:4028"]

# ── Docker ─────────────────────────────────────────────
PILOTARR_PORT=80       # host port exposed by nginx
